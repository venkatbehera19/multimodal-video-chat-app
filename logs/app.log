User: import streamlit as st
import requests
import uuid

API_URL = "http://localhost:8000"

st.set_page_config(page_title="Simple Video Chat", layout="wide")

if "session_id" not in st.session_state:
    st.session_state.session_id = str(uuid.uuid4())
if "chat_history" not in st.session_state:
    st.session_state.chat_history = []

with st.sidebar:
    st.title("⚙️ Configuration")
    
    target_video_id = st.text_input(
        "Target Video ID", 
        placeholder="e.g., 67_aMPDk2zw",
        help="Enter the ID of the video you want to chat with."
    )
    
    st.divider()
    
    st.subheader("Process New Video")
    yt_url = st.text_input("YouTube URL", placeholder="https://www.youtube.com/...")
    if st.button("Index Video", use_container_width=True):
        if yt_url:
            with st.spinner("Indexing..."):
                try:
                    response = requests.post(f"{API_URL}/upload", params={"youtube_link": yt_url})
                    if response.status_code in [200, 201]:
                        data = response.json()
                        new_id = data.get("meta") or data.get("video_id")
                        st.success(f"Indexed! ID: {new_id}")
                        st.code(new_id) # Easily copy the ID
                    else:
                        st.error("Upload failed.")
                except Exception as e:
                    st.error(f"Error: {e}")

    if st.button("Clear Chat", use_container_width=True):
        st.session_state.chat_history = []
        st.rerun()

st.title("💬 Video Chat")
if target_video_id:
    st.caption(f"Active Session: `{st.session_state.session_id}` | Chatting with: `{target_video_id}`")
else:
    st.warning("⚠️ Please enter a Video ID in the sidebar to start chatting.")

for chat in st.session_state.chat_history:
    with st.chat_message(chat["role"]):
        st.write(chat["content"])
        if "frames" in chat and chat["frames"]:
            cols = st.columns(min(len(chat["frames"]), 3))
            for idx, frame in enumerate(chat["frames"]):
                with cols[idx % 3]:
                    b64 = frame["base64"] if isinstance(frame, dict) else frame
                    st.image(f"data:image/jpeg;base64,{b64}", use_container_width=True)

if prompt := st.chat_input("Ask a question about the video..."):
    if not target_video_id:
        st.error("You must provide a Video ID in the sidebar.")
    else:
        st.session_state.chat_history.append({"role": "user", "content": prompt})
        with st.chat_message("user"):
            st.write(prompt)

        with st.chat_message("assistant"):
            with st.spinner("Thinking..."):
                try:
                    params = {
                        "query": prompt,
                        "session_id": st.session_state.session_id,
                        "video_id": target_video_id
                    }
                    response = requests.get(f"{API_URL}/chat", params=params)
                    
                    if response.status_code == 200:
                        data = response.json()
                        answer = data.get("answer", "No response.")
                        frames = data.get("sources", {}).get("frames", [])

                        st.write(answer)
                        
                        if frames:
                            st.markdown("### Visual Evidence")
                            cols = st.columns(min(len(frames), 3))
                            for idx, f_data in enumerate(frames):
                                with cols[idx % 3]:
                                    st.image(f"data:image/jpeg;base64,{f_data['base64']}", use_container_width=True)

                        st.session_state.chat_history.append({
                            "role": "assistant", 
                            "content": answer, 
                            "frames": frames
                        })
                    elif response.status_code == 429:
                        st.warning("⚠️ **Rate Limit Reached:** Google's free tier has a limit. Please wait about 60 seconds and try again.")
                        st.session_state.chat_history.pop()
                    else:
                        st.error(f"API Error ({response.status_code})")
                except Exception as e:
                    st.error(f"Request failed: {e}")


